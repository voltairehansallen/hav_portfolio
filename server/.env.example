# Base de données
# Local (XAMPP, root sans mot de passe par défaut) :
DATABASE_URL="mysql://root:@localhost:3306/hav_os_portfolio"
# Sur Railway, tu remplaceras cette valeur par l'URL fournie par Railway

# Serveur
PORT=5000
NODE_ENV=development

# Authentification
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# CORS — URL du frontend autorisé
CLIENT_URL="http://localhost:3000"

# Compte admin unique — utilisé uniquement par prisma/seed.js (npm run prisma:seed)
# Change le mot de passe avant le premier seed !
ADMIN_EMAIL="admin@havos.dev"
ADMIN_PASSWORD="change-me-before-seeding"

# HAV AI — clé Gemini (créée sur https://aistudio.google.com/apikey)
GEMINI_API_KEY="ta-cle-gemini"
GEMINI_MODEL="gemini-3.6-flash"
